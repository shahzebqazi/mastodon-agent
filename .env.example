# Copy to .env and fill in. Never commit .env.

# Your Mastodon server (scheme + host only, no /@username path)
MASTODON_INSTANCE_URL=https://example.social

# Create an app: Preferences → Development → New application
# Required scopes for posting: write:statuses (read if you add read features later)
MASTODON_ACCESS_TOKEN=your_access_token_here
